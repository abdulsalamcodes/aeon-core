{
  "name": "aeon-core",
  "version": "0.0.1",
  "private": true,
  "description": "Aeon greenfield core — Postgres + Drizzle + RLS modular monolith (ARCHITECTURE.md Phase 0)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/worker/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "bullmq": "^5.12.0",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.9.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vitest": "^2.0.5"
  }
}
